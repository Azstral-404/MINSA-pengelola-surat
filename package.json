{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:8080 && electron .\"",
    "electron:build": "vite build && electron-builder build --win --x64",
    "electron:build:dir": "vite build && electron-builder build --win --x64 --dir",
    "electron:build:nsis": "vite build && electron-builder build --win nsis --x64",
    "electron:build:msi": "vite build && electron-builder build --win msi --x64",
    "electron:build:msix": "vite build && electron-builder build --win appx --x64",
    "electron:build:portable": "vite build && electron-builder build --win portable --x64",
    "electron:build:all": "vite build && electron-builder build --win nsis msi portable --x64"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.462.0",
    "mammoth": "^1.11.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "lovable-tagger": "^1.1.13",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.azstral.minsa",
    "productName": "MINSA Surat Manager",
    "copyright": "Copyright © 2025 AZSTRAL",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/**/*.map",
      "!**/*.md",
      "!**/*.ts"
    ],
    "extraResources": [
      {
        "from": "public/minsa-icon.png",
        "to": "minsa-icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["ia32"]
        },
        {
          "target": "msi",
          "arch": ["x64"]
        },
        {
          "target": "msi",
          "arch": ["ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["ia32"]
        }
      ],
      "icon": "public/minsa-icon.png",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MINSA Surat Manager",
      "installerIcon": "public/minsa-icon.png",
      "uninstallerIcon": "public/minsa-icon.png",
      "installerHeaderIcon": "public/minsa-icon.png",
      "deleteAppDataOnUninstall": false,
      "menuCategory": "MINSA",
      "artifactName": "MINSA-Surat-Manager-Setup-${version}.exe",
      "include": "installer.nsh"
    },
    "msi": {
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MINSA Surat Manager",
      "artifactName": "MINSA-Surat-Manager-${version}.msi"
    },
    "appx": {
      "applicationId": "AZSTRALMINSASuratManager",
      "backgroundColor": "#1a103c",
      "displayName": "MINSA Surat Manager",
      "identityName": "AZSTRAL.MINSASuratManager",
      "publisher": "CN=AZSTRAL",
      "publisherDisplayName": "AZSTRAL",
      "languages": ["id-ID", "en-US"],
      "artifactName": "MINSA-Surat-Manager-${version}.msix"
    },
    "portable": {
      "artifactName": "MINSA-Surat-Manager-Portable-${version}.exe"
    },
    "publish": null
  }
}
